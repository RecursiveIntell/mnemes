[Unit]
Description=Pooled Memory authority service
After=network.target

[Service]
Type=simple
EnvironmentFile=%h/.config/pooled-memory/server.env
ExecStart=%h/.local/bin/pooled-memory-server ${POOLED_MEMORY_PORT} ${POOLED_MEMORY_DATA_DIR}
Restart=on-failure
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=%h/.local/share/pooled-memory
LockPersonality=true
RestrictSUIDSGID=true

[Install]
WantedBy=default.target
